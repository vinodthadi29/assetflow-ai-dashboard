// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// User and Authentication
model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  password        String
  avatar          String?
  role            UserRole        @default(EMPLOYEE)
  department      String?
  tokenVersion    Int             @default(1) // For token rotation
  lastLoginAt     DateTime?
  failedLoginAttempts Int         @default(0)
  lockedUntil     DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Relations
  allocationsTo     Allocation[] @relation("toUser")
  allocationsFrom   Allocation[] @relation("fromUser")
  bookings          Booking[]
  maintenanceTickets MaintenanceTicket[]
  audits            Audit[]
  auditItems        AuditItem[]
  approvals         Approval[]
  activities        Activity[]
  sessions          Session[]
  notifications     Notification[]

  @@index([email])
  @@index([role])
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

// Core Asset Model
model Asset {
  id                String              @id @default(cuid())
  assetId           String              @unique // e.g., AST-001
  name              String
  description       String?
  category          AssetCategory
  subcategory       String?
  status            AssetStatus         @default(AVAILABLE)
  location          String
  owner             String?
  assignedTo        String?
  purchaseDate      DateTime?
  purchaseValue     Float?
  currentValue      Float?
  serialNumber      String?
  qrCode            String?              @unique
  manufacturer      String?
  model             String?
  warrantyExpiry    DateTime?
  depreciationRate  Float?              @default(0)
  
  // Metadata
  tags              String[]            @default([])
  customFields      Json?               // Flexible custom fields
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  // Relations
  allocations       Allocation[]
  bookings          Booking[]
  maintenance       MaintenanceTicket[]
  auditItems        AuditItem[]
  activities        Activity[]
  files             AssetFile[]

  @@unique([serialNumber]) // Enforce unique serial numbers
  @@index([status])
  @@index([location])
  @@index([category])
  @@index([deletedAt])
  @@index([qrCode])
}

enum AssetCategory {
  COMPUTERS
  MONITORS
  FURNITURE
  EQUIPMENT
  VEHICLES
  MACHINERY
  TOOLS
  OTHER
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  IN_MAINTENANCE
  RESERVED
  RETIRED
  LOST
  DAMAGED
}

// Asset Allocation Model
model Allocation {
  id                String              @id @default(cuid())
  allocationId      String              @unique // e.g., ALLOC-001
  assetId           String
  asset             Asset               @relation(fields: [assetId], references: [id])
  fromUserId        String?
  fromUser          User?               @relation("fromUser", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User                @relation("toUser", fields: [toUserId], references: [id])
  
  status            AllocationStatus    @default(PENDING)
  reason            String?
  startDate         DateTime
  endDate           DateTime?
  approvedBy        String?
  approvedAt        DateTime?
  rejectedReason    String?
  rejectedAt        DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  activities        Activity[]

  @@index([assetId])
  @@index([toUserId])
  @@index([status])
}

enum AllocationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

// Asset Booking Model
model Booking {
  id                String              @id @default(cuid())
  bookingId         String              @unique // e.g., BOOK-001
  assetId           String
  asset             Asset               @relation(fields: [assetId], references: [id])
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  
  startDate         DateTime
  endDate           DateTime
  purpose           String?
  status            BookingStatus       @default(PENDING)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@index([startDate])
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

// Maintenance Model
model MaintenanceTicket {
  id                String              @id @default(cuid())
  ticketId          String              @unique // e.g., MAINT-001
  assetId           String
  asset             Asset               @relation(fields: [assetId], references: [id])
  createdBy         String
  createdByUser     User                @relation(fields: [createdBy], references: [id])
  
  title             String
  description       String?
  type              MaintenanceType
  priority          Priority            @default(MEDIUM)
  status            MaintenanceStatus   @default(OPEN)
  
  scheduledDate     DateTime?
  completedDate     DateTime?
  estimatedCost     Float?
  actualCost        Float?
  notes             String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([priority])
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
  REPAIR
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

// Audit Model
model Audit {
  id                String              @id @default(cuid())
  auditId           String              @unique // e.g., AUDIT-001
  createdBy         String
  createdByUser     User                @relation(fields: [createdBy], references: [id])
  
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  status            AuditStatus         @default(PENDING)
  completionPercentage Int             @default(0)
  notes             String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  items             AuditItem[]

  @@index([status])
}

enum AuditStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Audit Items Model
model AuditItem {
  id                String              @id @default(cuid())
  auditId           String
  audit             Audit               @relation(fields: [auditId], references: [id], onDelete: Cascade)
  assetId           String
  asset             Asset               @relation(fields: [assetId], references: [id])
  verifiedBy        String?
  verifiedByUser    User?               @relation(fields: [verifiedBy], references: [id])
  
  status            AuditItemStatus     @default(PENDING)
  location          String?
  condition         AssetCondition
  notes             String?
  verifiedAt        DateTime?
  
  createdAt         DateTime            @default(now())

  @@index([auditId])
  @@index([assetId])
  @@index([status])
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  DISCREPANCY
  MISSING
  EXTRA
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

// Approval Workflow Model
model Approval {
  id                String              @id @default(cuid())
  approvalId        String              @unique
  type              ApprovalType
  entityId          String              // ID of the entity being approved (allocation, booking, etc.)
  requestedBy       String
  requestedByUser   User                @relation(fields: [requestedBy], references: [id])
  
  status            ApprovalStatus      @default(PENDING)
  comments          String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([type])
  @@index([status])
}

enum ApprovalType {
  ALLOCATION
  BOOKING
  MAINTENANCE
  ASSET_RETIREMENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Activity/Audit Log Model
model Activity {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  assetId           String?
  asset             Asset?              @relation(fields: [assetId], references: [id])
  allocationId      String?
  allocation        Allocation?         @relation(fields: [allocationId], references: [id])
  
  action            ActivityAction
  description       String?
  metadata          Json?               // Store additional context
  
  createdAt         DateTime            @default(now())

  @@index([userId])
  @@index([assetId])
  @@index([action])
}

enum ActivityAction {
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_DELETED
  ALLOCATION_REQUESTED
  ALLOCATION_APPROVED
  ALLOCATION_REJECTED
  BOOKING_CREATED
  BOOKING_APPROVED
  BOOKING_CANCELLED
  MAINTENANCE_CREATED
  MAINTENANCE_COMPLETED
  AUDIT_STARTED
  AUDIT_COMPLETED
  USER_LOGIN
  SETTINGS_CHANGED
}

// Session Model for Authentication
model Session {
  id                String              @id @default(cuid())
  userId            String
  refreshToken      String              @unique
  expiresAt         DateTime
  createdAt         DateTime            @default(now())
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

// Notification Model
model Notification {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              NotificationType
  title             String
  message           String
  actionUrl         String?
  metadata          String?             // JSON for additional data
  readAt            DateTime?
  createdAt         DateTime            @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

enum NotificationType {
  ALLOCATION_REQUEST
  ALLOCATION_APPROVED
  ALLOCATION_REJECTED
  MAINTENANCE_ALERT
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  ASSET_RETIRED
  COMPLIANCE_ALERT
  SYSTEM_ALERT
}

// Asset Files for documentation, manuals, invoices, etc
model AssetFile {
  id                String              @id @default(cuid())
  assetId           String
  asset             Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  filename          String
  filepath          String
  fileType          String              // IMAGE, DOCUMENT, MANUAL, INVOICE, RECEIPT, WARRANTY
  fileSize          Int
  mimeType          String
  uploadedBy        String
  uploadedAt        DateTime            @default(now())
  deletedAt         DateTime?

  @@index([assetId])
  @@index([fileType])
  @@index([uploadedAt])
}

// Security Audit Log - tracks sensitive operations
model SecurityAuditLog {
  id                String              @id @default(cuid())
  userId            String?
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  action            String              // LOGIN, LOGOUT, FAILED_LOGIN, PERMISSION_CHANGE, ALLOCATION_APPROVED, etc
  entityType        String?             // Asset, Allocation, Maintenance, etc
  entityId          String?
  status            String              // SUCCESS, FAILED, BLOCKED
  reason            String?
  ipAddress         String?
  userAgent         String?
  metadata          Json?               // Additional context
  createdAt         DateTime            @default(now())

  @@index([userId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@index([ipAddress])
}
